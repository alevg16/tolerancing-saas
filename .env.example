# ----------------------------------------------------------------------------
# Supabase — Project Settings → Data API / API Keys
# Create a project at https://supabase.com, then copy these values.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Bypasses Row-Level Security — used by the Stripe webhook to sync
# subscription state (Phase 1, item 5). NEVER expose this to the client / commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL of the app — used to build auth redirect/callback links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Stripe — billing spine (Phase 1, item 5). Not wired yet; placeholders only.
# ----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
